# ═══════════════════════════════════════════════════════════════════════════════
# STAMPEDE — Variables de entorno para PRODUCCIÓN
# ───────────────────────────────────────────────────────────────────────────────
# Copia este archivo como .env.production.local para pruebas locales
# En Vercel: ve a Project → Settings → Environment Variables y pega cada valor
# ═══════════════════════════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=STAMPEDE
NEXT_PUBLIC_APP_URL=https://TU-DOMINIO.com        # ← cambia por tu dominio real

# ── Base de datos (Neon o Supabase — gratis) ─────────────────────────────────
# Opción A: Neon  → https://neon.tech  → New Project → copia la connection string
# Opción B: Supabase → https://supabase.com → Settings → Database → URI
DATABASE_URL=postgresql://USER:PASSWORD@HOST/stampede?sslmode=require
DIRECT_URL=postgresql://USER:PASSWORD@HOST/stampede?sslmode=require

# ── Clerk (autenticación) ─────────────────────────────────────────────────────
# https://dashboard.clerk.com → Tu app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=YOUR_CLERK_PUBLISHABLE_KEY
CLERK_SECRET_KEY=YOUR_CLERK_SECRET_KEY
CLERK_WEBHOOK_SECRET=YOUR_CLERK_WEBHOOK_SECRET

# Clerk URLs (deja estas exactas, solo cambia el dominio en NEXT_PUBLIC_APP_URL)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# ── Stripe (pagos) ────────────────────────────────────────────────────────────
# https://dashboard.stripe.com → Developers → API Keys
# En producción usa las keys "live" (no "test")
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=YOUR_STRIPE_PUBLISHABLE_KEY
STRIPE_SECRET_KEY=YOUR_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=YOUR_STRIPE_WEBHOOK_SECRET

# Stripe Product IDs — créalos en https://dashboard.stripe.com/products
# Crea un producto "STAMPEDE PRO" con dos precios: mensual y anual
STRIPE_PRO_MONTHLY_PRICE_ID=price_XXXXXXXXXXXXXXXXXXXXXXXX   # ej: $4.99/mes
STRIPE_PRO_YEARLY_PRICE_ID=price_XXXXXXXXXXXXXXXXXXXXXXXX    # ej: $39.99/año

# ── OpenAI (AI Coach) ─────────────────────────────────────────────────────────
# https://platform.openai.com/api-keys
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
OPENAI_MODEL=gpt-4o-mini                                     # más barato, funciona bien

# ── Upstash Redis (rate limiting) ─────────────────────────────────────────────
# https://console.upstash.com → New Database → REST API
UPSTASH_REDIS_REST_URL=YOUR_UPSTASH_REDIS_REST_URL
UPSTASH_REDIS_REST_TOKEN=YOUR_UPSTASH_REDIS_REST_TOKEN

# ── Flags ─────────────────────────────────────────────────────────────────────
SKIP_ONBOARDING=false
