# ============================================================
# STAMPEDE - Production Environment Variables
# Use these values in Vercel > Project Settings > Environment Variables
# ============================================================

# App
NEXT_PUBLIC_APP_NAME=STAMPEDE
NEXT_PUBLIC_APP_URL=https://TU-DOMINIO.com

# Database
DATABASE_URL=postgresql://USER:PASSWORD@HOST/stampede?sslmode=require
DIRECT_URL=postgresql://USER:PASSWORD@HOST/stampede?sslmode=require

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=YOUR_CLERK_PUBLISHABLE_KEY
CLERK_SECRET_KEY=YOUR_CLERK_SECRET_KEY
CLERK_WEBHOOK_SECRET=YOUR_CLERK_WEBHOOK_SECRET
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# Wompi
WOMPI_PUBLIC_KEY=YOUR_WOMPI_PUBLIC_KEY
WOMPI_INTEGRITY_SECRET=YOUR_WOMPI_INTEGRITY_SECRET
WOMPI_EVENTS_SECRET=YOUR_WOMPI_EVENTS_SECRET

# Stripe (optional / legacy while migrating)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=YOUR_STRIPE_PUBLISHABLE_KEY
STRIPE_SECRET_KEY=YOUR_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=YOUR_STRIPE_WEBHOOK_SECRET
STRIPE_PRO_MONTHLY_PRICE_ID=price_XXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_PRO_YEARLY_PRICE_ID=price_XXXXXXXXXXXXXXXXXXXXXXXX

# OpenAI
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
OPENAI_MODEL=gpt-4o-mini

# Upstash Redis
UPSTASH_REDIS_REST_URL=YOUR_UPSTASH_REDIS_REST_URL
UPSTASH_REDIS_REST_TOKEN=YOUR_UPSTASH_REDIS_REST_TOKEN

# Flags
SKIP_ONBOARDING=false
